{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-openssl": "*",
        "ext-zip": "*",
        "aws/aws-sdk-php": "^3.0",
        "barryvdh/laravel-dompdf": "^3.1",
        "botman/botman": "^2.8",
        "google/apiclient": "^2.16",
        "guzzlehttp/guzzle": "^7.0",
        "intervention/image": "^3.0",
        "jenssegers/agent": "^2.6",
        "kreait/laravel-firebase": "^6.1",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.2",
        "laravel/socialite": "^5.6",
        "laravel/telescope": "^5.15",
        "laravel/tinker": "^2.8",
        "league/flysystem-aws-s3-v3": "^3.30",
        "maatwebsite/excel": "^3.1.63",
        "matscode/paystack": "^1.10",
        "mercadopago/dx-php": "3.7.1",
        "paytabscom/laravel_paytabs": "^1.9",
        "phpmailer/phpmailer": "^6.7",
        "predis/predis": "^2.1",
        "razorpay/razorpay": "2.*",
        "sendgrid/sendgrid": "^8.1",
        "spatie/laravel-backup": "^9.3",
        "spatie/laravel-permission": "^6.0",
        "srmklive/paypal": "~3.0",
        "stripe/stripe-php": "^19.0",
        "twilio/sdk": "^8.8",
        "vonage/client": "^4.2"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.9",
        "barryvdh/laravel-ide-helper": "*",
        "spatie/laravel-ignition": "^2.0",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "phpmd/phpmd": "^2.13",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php artisan migrate:fresh --seed"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
